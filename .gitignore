# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# personal assets (CV and project images)
public/projects/*.jpg
public/projects/*.png
public/projects/*.jpeg
public/projects/*.webp
!public/projects/.gitkeep

# AI assistant working files
.ai/

# fetched portfolio content (written by scripts/sync-data.mjs)
src/lib/portfolio-data.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# legacy local config (content now lives in the portfolio-data repo)
src/lib/data.config.ts
